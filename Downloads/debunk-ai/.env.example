# Database Configuration
# For local development with SQLite:
# DATABASE_PROVIDER=sqlite
# DATABASE_URL=file:./dev.db

# For production with PostgreSQL (Vercel Postgres or any PostgreSQL):
# DATABASE_PROVIDER=postgresql
# DATABASE_URL=postgresql://user:password@host:port/database

DATABASE_PROVIDER=sqlite
DATABASE_URL=file:./dev.db

# JWT Secret for session authentication
# IMPORTANT: Change this to a secure random string in production
JWT_SECRET=change-me-before-production

# HuggingFace API Configuration (Required for production)
# Get your token from https://huggingface.co/settings/tokens
# This enables real AI-powered hints, chat, and educational feedback
# In production (Vercel), this should be configured in project environment settings
HF_API_KEY=

# Application URL (used for CORS and redirects)
APP_URL=http://localhost:3000

# Node environment
NODE_ENV=development
